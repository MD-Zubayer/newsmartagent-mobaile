{
  "expo": {
    "name": "newsmartagent-mobaile",
    "slug": "newsmartagent-mobaile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "newsmartagentmobaile",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#208AEF"
    },
    "ios": {
      "icon": "./assets/images/icon.png",
      "supportsTabletMode": true,
      "bundleIdentifier": "com.newsmartagent.mobile"
    },
    "android": {
      "package": "com.newsmartagent.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#208AEF",
        "foregroundImage": "./assets/images/icon.png"
      },
      "splash": {
        "image": "./assets/images/icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#208AEF"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "https",
              "host": "newsmartagent.com",
              "pathPrefix": "/reset-password"
            },
            {
              "scheme": "https",
              "host": "www.newsmartagent.com",
              "pathPrefix": "/reset-password"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "android": {
            "image": "./assets/images/icon.png",
            "imageWidth": 200
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.0"
          },
          "extra": {
        "enableBundleCompression": false
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9ac6f146-4a95-46b8-a926-59972bfe2e59"
      }
    }
  }
}